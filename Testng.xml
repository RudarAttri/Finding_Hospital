<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG suite for Corporate Wellness data-driven tests.
    Reads test data from   : TestData/CorporateWellnessData.xlsx
    Writes status back into: same Excel (ActualStatus column)
    Generates Extent HTML  : Reports/Extent/ExtentReport_*.html

    ★ EXECUTION ORDER ★
      1. CorporateWellnessBDDTests      → Cucumber BDD runs FIRST  (sequential)
      2. CorporateWellnessRegistrationTests → TestNG runs SECOND (parallel)

    ★ PARALLEL EXECUTION (TestNG block only) ★
      • parallel="methods"               → run test methods in parallel
      • thread-count="6"                 → 6 simultaneous threads
      • data-provider-thread-count="6"   → 6 DataProvider rows run at once

    Coexists with the BDD/Cucumber framework:
      • Cucumber tests run via TestRunner.java (untouched)
      • TestNG tests run via this Testng.xml (PARALLEL)
      • Both use the same DriverFactory (ThreadLocal) — no conflict
-->
<suite name="CorporateWellnessSuite"
       verbose="2"
       preserve-order="true">

    <!--
        ⚠️ parallel and thread-count are moved from <suite> level
           to <test> level — so ONLY the TestNG block runs in parallel.
           BDD block stays sequential to avoid Cucumber thread conflicts.
    -->

    <!-- ── Listeners — activates ExtentReports automatically ──────────────── -->
    <listeners>
        <listener class-name="utilities.ExtentTestListener"/>
    </listeners>


    <test name="CorporateWellnessBDDTests"
          preserve-order="true">
        <classes>
            <class name="testRunner.TestRunner"/>
        </classes>
    </test>


    <test name="CorporateWellnessRegistrationTests"
          parallel="methods"
          thread-count="6">
        <classes>
            <class name="org.example.CorporateWellnessTest">
                <methods>
                    <include name="testCorporateWellnessRegistration"/>
                </methods>
            </class>
        </classes>
    </test>

</suite>